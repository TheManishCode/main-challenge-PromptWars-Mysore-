# ── Required for AI features ─────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Low-latency model used for the live voice conversation mode
GEMINI_VOICE_MODEL=gemini-2.5-flash-lite

# ── Required for production persistence ───────────────────────────────────────
DATABASE_URL=

# ── Required for production security ──────────────────────────────────────────
APP_ORIGIN=https://your-project.vercel.app
DATA_ENCRYPTION_KEY=
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"

# ── Required for production authentication (Clerk) ────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
TESTER_LOGIN_SECRET=
# Optional. Used to sign the one-click tester session cookie.

# ── Required for production rate limiting (Upstash Redis) ─────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Required for scheduled cron jobs ──────────────────────────────────────────
CRON_SECRET=

# ── OAuth providers — enter these in the Clerk dashboard, not as app env vars ─
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
